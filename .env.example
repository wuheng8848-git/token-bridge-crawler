# Token Bridge Crawler 环境变量配置

# 主项目 API（抓取成功后 POST supplier_catalog_staging/import；须与主项目 apps/api 的 TB_ADMIN_API_TOKEN 一致）
TB_BASE_URL=http://127.0.0.1:8080
TB_ADMIN_API_TOKEN=your_admin_token_here
# 可选：每批导入条数（默认 50）
# TB_IMPORT_BATCH_SIZE=50

# 数据库存储（可以与 TB 共用，也可以独立）
# 格式: postgres://user:password@host:port/database?sslmode=disable
CRAWLER_DATABASE_URL=postgres://postgres:password@localhost:5432/token_bridge?sslmode=disable

# 厂商 API Keys（某些厂商需要）
OPENAI_API_KEY=sk-xxx

# AI 日报配置
CRAWLER_AI_API_KEY=sk-xxx

# 邮件配置
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Discord 采集器配置
# 获取 Bot Token: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# 监控的频道ID列表（逗号分隔）
# 获取频道ID: 在 Discord 中右键频道 -> 复制ID（需要开启开发者模式）
DISCORD_CHANNEL_IDS=123456789012345678,987654321098765432

# 翻译服务配置
TRANSLATION_ENABLED=false
TRANSLATION_BATCH_SIZE=5

# 火山引擎翻译（推荐，200万字符/月免费）
VOLCENGINE_ACCESS_KEY_ID=your_access_key_id
VOLCENGINE_SECRET_ACCESS_KEY=your_secret_access_key

# 百度翻译
BAIDU_APP_ID=your_app_id
BAIDU_API_KEY=your_api_key      # 大模型翻译
BAIDU_APP_SECRET=your_app_secret # 通用翻译

# OpenRouter 翻译（付费备选）
OPENROUTER_API_KEY=your_openrouter_key

# 有道翻译（付费备选）
YOUDAO_APP_KEY=your_app_key
YOUDAO_APP_SECRET=your_app_secret
