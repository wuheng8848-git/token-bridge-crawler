# EditorConfig - 跨编辑器代码风格配置
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[*.{sql,md}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.{ps1,psm1}]
indent_style = space
indent_size = 4
end_of_line = crlf

[*.tsx, *.ts]
indent_style = space
indent_size = 2
