# Token Bridge Intelligence 环境变量配置
# 复制为 .env 后填写实际值

# 数据库配置
DB_USER=tbuser
DB_PASSWORD=your_secure_password_here
DB_NAME=tokenbridge

# Tavily 搜索配置（可选，推荐配置）
# 获取地址: https://tavily.com (免费版每月1000次搜索)
TAVILY_API_KEY=

# 翻译服务配置（可选，不填则禁用翻译）
OPENROUTER_API_KEY=
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_APP_SECRET=
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=

# AI日报配置（可选）
CRAWLER_AI_API_KEY=

# 邮件配置（可选）
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
